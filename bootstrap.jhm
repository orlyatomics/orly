{
  targets: [tools/nycr/nycr],
  "cmd": {
    "+g++" : [
      "-U_FORTIFY_SOURCE",
      "-O3",
      "-g1",
      "-DNDEBUG",
      "-flto=auto",
      "-Wno-unused",
      "-Wno-unused-parameter",
      "-Wno-unused-result",
      "-DBOOTSTRAP"
    ],
    "+gcc": [
      "-U_FORTIFY_SOURCE",
      "-O3",
      "-g1",
      "-DNDEBUG",
      "-flto=auto",
      "-DBOOTSTRAP"
    ],
    "flex": {
      "+g++": [
        "-U_FORTIFY_SOURCE",
        "-O3",
        "-g1",
        "-DNDEBUG",
        "-flto=auto",
        "-DBOOTSTRAP"
      ]
    },
    "bison": {
      "+g++": [
        "-U_FORTIFY_SOURCE",
        "-O3",
        "-g1",
        "-DNDEBUG",
        "-flto=auto",
        "-DBOOTSTRAP"
      ]
    },
    "ld": {
      "+flags": [
        "-O3",
        "-flto=auto"
      ]
    }
  }
}